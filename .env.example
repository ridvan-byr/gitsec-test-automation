# =============================================================================
# GitSec E2E Test Ortam Değişkenleri
# =============================================================================
# Kullanım: Bu dosyayı kopyalayıp .env olarak kaydedin ve değerleri doldurun.
#   cp .env.example .env
#
# [ZORUNLU]  → Çoğu test suite'i için gerekli; eksikse test başlamadan hata verir.
# [KOŞULLU]  → Belirli testler için gerekli (açıklamada belirtilir).
# [OPSİYONEL] → Varsayılan davranışı değiştirmek için.
# =============================================================================


# -----------------------------------------------------------------------------
# [ZORUNLU] Temel ortam — tüm E2E testleri
# -----------------------------------------------------------------------------
WORKSPACE_ID=753
DASHBOARD_BASE_URL=https://dev.dashboard.gitsec.io
API_BASE_URL=https://dev.api.gitsec.io


# -----------------------------------------------------------------------------
# [ZORUNLU] Uygulama girişi — auth.setup, login, çoğu authenticated test
# -----------------------------------------------------------------------------
E2E_USER_EMAIL=your-test-user@example.com
E2E_USER_PASSWORD=your-test-password


# -----------------------------------------------------------------------------
# [KOŞULLU] Gerçek şifre sıfırlama e-postası testi
# Uygulamada kayıtlı, IMAP erişimi açık ayrı bir test posta hesabı kullanın.
# Test sıfırlama linkini açar ancak hesabın şifresini değiştirmez.
# -----------------------------------------------------------------------------
FORGOT_PASSWORD_EMAIL=your-registered-test-user@gmail.com
FORGOT_PASSWORD_MAIL_USER=your-imap-login@gmail.com
FORGOT_PASSWORD_MAIL_PASSWORD=your-16-character-app-password
# FORGOT_PASSWORD_MAIL_IMAP_HOST=imap.gmail.com
# FORGOT_PASSWORD_MAIL_IMAP_PORT=993


# -----------------------------------------------------------------------------
# [KOŞULLU] GitHub OAuth — github-connect, auth.setup, repo/restore testleri
# Belirtilmezse E2E_USER_EMAIL / E2E_USER_PASSWORD kullanılır (auth.setup).
# github-connect ve full-flow-auditor için ayrı GitHub hesabı önerilir.
# -----------------------------------------------------------------------------
GITHUB_TEST_USER=your-github-user@example.com
GITHUB_TEST_PASSWORD=your-github-password

# Kayıtlı playwright/.auth/github.json oturumunu kullanmak için:
# GITHUB_USE_SAVED_SESSION=1


# -----------------------------------------------------------------------------
# [KOŞULLU] GitHub e-posta 2FA (IMAP) — sudo / "Verify via email" akışları
# Gmail uygulama şifresi (16 karakter) ile IMAP erişimi gerekir.
# -----------------------------------------------------------------------------
GITHUB_MAIL_USER=sen@gmail.com
GITHUB_MAIL_PASSWORD=abcdabcdabcdabcd
# GITHUB_MAIL_IMAP_HOST=imap.gmail.com
# GITHUB_MAIL_IMAP_PORT=993
# GITHUB_SUDO_WAIT_MS=90000
# GITHUB_MAIL_DEBUG=0


# -----------------------------------------------------------------------------
# [KOŞULLU] Storage testleri — E2E_STORAGE_PROVIDER değerine göre doldurun
# Değerler: aws | azure | huawei | gdrive | onedrive
# -----------------------------------------------------------------------------
E2E_STORAGE_PROVIDER=aws

# AWS S3 (E2E_STORAGE_PROVIDER=aws)
AWS_S3_BUCKET=your-bucket-name
AWS_ACCESS_KEY_ID=your-aws-access-key-id
AWS_SECRET_ACCESS_KEY=your-aws-secret-access-key
AWS_REGION=eu-central-1

# Azure Blob (E2E_STORAGE_PROVIDER=azure)
AZURE_CONNECTION_STRING=DefaultEndpointsProtocol=https;AccountName=youraccount;AccountKey=yourkey;EndpointSuffix=core.windows.net
AZURE_FOLDER_PATH=/

# Huawei OBS (E2E_STORAGE_PROVIDER=huawei)
HUAWEI_ACCESS_KEY_ID=your-huawei-access-key-id
HUAWEI_SECRET_ACCESS_KEY=your-huawei-secret-access-key
HUAWEI_BUCKET=your-huawei-bucket-name
HUAWEI_REGION=Europe (Turkey - West)


# -----------------------------------------------------------------------------
# [KOŞULLU] Google Drive OAuth — E2E_STORAGE_PROVIDER=gdrive
# Gerçek Chrome + kayıtlı oturum (playwright/.auth/google-session.json) önerilir.
# -----------------------------------------------------------------------------
GOOGLE_TEST_USER=your-google-user@gmail.com
GOOGLE_TEST_PASSWORD=your-google-password
GOOGLE_TOTP_SECRET=your-base32-totp-secret


# -----------------------------------------------------------------------------
# [OPSİYONEL] Scheduler testleri — schedulers.spec.ts
# -----------------------------------------------------------------------------
# E2E_SCHEDULE_NAME=
# E2E_SCHEDULE_TYPE=Daily
# E2E_SCHEDULE_TIME=02:00
# E2E_TIMEZONE=Europe/Istanbul
# E2E_WEEKDAY=Mon
# E2E_MONTHDAY=1
# E2E_CRON_EXPR=0 2 * * ?
# E2E_INCLUDE_CODE=true
# E2E_INCLUDE_PR=true
# E2E_INCLUDE_ISSUES=true


# -----------------------------------------------------------------------------
# [OPSİYONEL] Repo kapsam testleri
# -----------------------------------------------------------------------------
# E2E_INCLUDE_MODE=one_repo
# E2E_EXCLUDE_MODE=one_repo


# -----------------------------------------------------------------------------
# [DİKKAT] Gerçek lisans değiştirme testi — license-change.spec.ts
# Hesabın lisansını gerçekten değiştirir. Enterprise yalnızca Contact Sales akışıdır.
# -----------------------------------------------------------------------------
# E2E_LICENSE_TARGET_PLAN=Startup
# E2E_LICENSE_TARGET_INTERVAL=monthly
# Iyzico ekranındaki parantez içi kod okunamazsa kullanılacak yedek:
# E2E_IYZICO_SMS_CODE=123456
# E2E_IYZICO_CARD_HOLDER=Test User
# E2E_IYZICO_CARD_NUMBER=0000000000000000
# E2E_IYZICO_CARD_EXPIRY=12/30
# E2E_IYZICO_CARD_CVC=123


# -----------------------------------------------------------------------------
# [OPSİYONEL] Setup ve CI davranışı
# -----------------------------------------------------------------------------
# Auth setup'ı atla (register/login testleri için otomatik algılanır):
# SKIP_GLOBAL_SETUP=true
