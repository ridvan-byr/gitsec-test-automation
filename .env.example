E2E_USER_EMAIL=your-test-user@example.com
E2E_USER_PASSWORD=your-test-password
GITHUB_TEST_USER=your-github-user@example.com
GITHUB_TEST_PASSWORD=your-github-password
# Kayıtlı playwright/.auth/github.json (ridvan-byr vb.) yerine yukarıdaki hesapla giriş için bunu EKLEMEYİN.
# Eski github.json oturumunu bilinçli kullanmak için: GITHUB_USE_SAVED_SESSION=1
WORKSPACE_ID=753
DASHBOARD_BASE_URL=https://dev.dashboard.gitsec.io
API_BASE_URL=https://dev.api.gitsec.io

# GitHub "Send a code via email" — Gmail uygulama şifresi (16 karakter) ile IMAP
GITHUB_MAIL_USER=sen@gmail.com
GITHUB_MAIL_PASSWORD=abcdabcdabcdabcd
# GITHUB_MAIL_IMAP_HOST=imap.gmail.com
# GITHUB_MAIL_IMAP_PORT=993

# Install & Authorize sonrası sudo/Confirm access gecikirse ms (Verify via email + IMAP öncesi bekleme)
# GITHUB_SUDO_WAIT_MS=90000
